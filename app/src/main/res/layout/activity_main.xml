<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_light">

    <!-- MINIMALIST HEADER BAR (No Top Bar - Sleek Minimal Header) -->
    <RelativeLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:paddingHorizontal="20dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="StatusMax"
            android:textColor="@color/black"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Working Dark/Light Mode Switch -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtThemeMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIGHT"
                android:textColor="@color/gray_dark"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchTheme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/black"
                app:trackTint="@color/slate_grey" />
        </LinearLayout>
    </RelativeLayout>

    <!-- SCREEN 1: HQ COMPRESS & ENHANCER -->
    <ScrollView
        android:id="@+id/screenCompress"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/headerBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Card: Select Video -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSelect"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/lblTitle1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="HQ Video Optimizer"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/lblDesc1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Menghaluskan dan menstabilkan video Anda agar lolos kompresi kasar WhatsApp."
                        android:textColor="@color/gray_dark"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btnSelectVideo"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="20dp"
                        android:backgroundTint="@color/black"
                        android:text="PILIH VIDEO"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        app:cornerRadius="10dp" />

                    <TextView
                        android:id="@+id/tvSelectedFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Belum ada video yang dipilih."
                        android:textAlignment="center"
                        android:textColor="@color/gray_dark"
                        android:textSize="12sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Optimasi Penjernih (Ultra Clear) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEnhance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/lblTitle2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Menerapkan Filter Penajam"
                            android:textColor="@color/black"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <!-- Switch untuk Mode Jernih -->
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchEnhance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:checked="true"
                            app:thumbTint="@color/black"
                            app:trackTint="@color/slate_grey" />

                    </RelativeLayout>

                    <TextView
                        android:id="@+id/lblDesc2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Menggunakan unsharp mask ringan untuk mempertajam tepi video tanpa membuat video lag/patah-patah saat diputar di HP kentang."
                        android:textColor="@color/gray_dark"
                        android:textSize="11sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Loading Progress Log (The "Cool" Progress Screen) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="2dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/lblProgress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Status Pemrosesan Video"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/progressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:indeterminate="true"
                        android:progressTint="@color/black" />

                    <!-- Live Step Progress Logs -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/logStep1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="○ Membaca metadata &amp; orientasi video..."
                            android:textColor="@color/gray_dark"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/logStep2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="○ Menerapkan filter penajam (unsharp)..."
                            android:textColor="@color/gray_dark"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/logStep3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="○ Mengonversi audio ke standar stereo AAC..."
                            android:textColor="@color/gray_dark"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/logStep4"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="○ Melakukan encoding kompresi presisi x264..."
                            android:textColor="@color/gray_dark"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Big Action Buttons -->
            <Button
                android:id="@+id/btnProcessVideo"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/black"
                android:text="PROSES &amp; OPTIMALKAN VIDEO"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="10dp"
                tools:visibility="visible" />

            <Button
                android:id="@+id/btnShare"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/black"
                android:text="BAGIKAN KE STATUS WHATSAPP"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="10dp"
                tools:visibility="visible" />

        </LinearLayout>
    </ScrollView>

    <!-- SCREEN 2: STATUS SAVER (UNDUH STATUS) -->
    <LinearLayout
        android:id="@+id/screenSaver"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/headerBar"
        tools:visibility="gone">

        <TextView
            android:id="@+id/lblTitleSaver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status WhatsApp Aktif"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lblDescSaver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Menampilkan semua status WhatsApp teman yang aktif secara lokal di HP Anda."
            android:textColor="@color/gray_dark"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnGrantFolder"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/black"
            android:text="HUBUNGKAN FOLDER STATUS WHATSAPP"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:cornerRadius="10dp" />

        <!-- Grid of Statuses -->
        <GridView
            android:id="@+id/gridStatuses"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="16dp"
            android:numColumns="3"
            android:horizontalSpacing="8dp"
            android:verticalSpacing="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvEmptySaver"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Belum terhubung ke WhatsApp. Klik tombol hitam di atas."
            android:textColor="@color/gray_dark"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- SCREEN 3: RECOVERY CENTER (Pusat Pemulihan Pesan Terhapus & 1x Lihat) -->
    <ScrollView
        android:id="@+id/screenDeleted"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/headerBar"
        tools:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/lblTitleRecovery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pusat Pemulihan (Anti-Tarik)"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lblDescRecovery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Memulihkan chat terhapus, foto 1x dilihat, dan status yang dihapus."
                android:textColor="@color/gray_dark"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnGrantNotification"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/black"
                android:text="AKTIFKAN ANTI-TARIK CHAT"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="10dp" />

            <!-- Sub-Section 1: View Once Intercepted Images -->
            <TextView
                android:id="@+id/lblSubViewOnce"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="📷 Foto 1x Dilihat Terpulihkan"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold" />

            <GridView
                android:id="@+id/gridDeleted"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="8dp"
                android:numColumns="3"
                android:horizontalSpacing="8dp"
                android:verticalSpacing="8dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvEmptyDeleted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:padding="16dp"
                android:text="Belum mendeteksi adanya foto 1x dilihat."
                android:textColor="@color/gray_dark"
                android:textSize="12sp" />

            <!-- Sub-Section 2: Deleted Chats Log -->
            <TextView
                android:id="@+id/lblSubChats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="💬 Obrolan WhatsApp Terhapus"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardChats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="1dp">

                <TextView
                    android:id="@+id/tvDeletedChatsLog"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:padding="12dp"
                    android:scrollbars="vertical"
                    android:text="Belum mendeteksi adanya pesan obrolan yang dihapus oleh teman."
                    android:textColor="@color/gray_dark"
                    android:textSize="12sp" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- FUTURISTIC BOTTOM NAVIGATION BAR -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="@color/white"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Tab 1: Compress -->
        <LinearLayout
            android:id="@+id/tabCompress"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTabCompress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HQ Upload"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Tab 2: Saver -->
        <LinearLayout
            android:id="@+id/tabSaver"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTabSaver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unduh Status"
                android:textColor="@color/gray_dark"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Tab 3: Recovery -->
        <LinearLayout
            android:id="@+id/tabDeleted"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTabDeleted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Anti-Tarik"
                android:textColor="@color/gray_dark"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
