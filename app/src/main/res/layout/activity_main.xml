<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_light"
    tools:context=".MainActivity">

    <!-- Top Action Bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/whatsapp_green_dark"
        app:title="StatusMax Pro"
        app:titleTextColor="@color/white"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- SCREEN 1: HQ COMPRESS & ENHANCER -->
    <ScrollView
        android:id="@+id/screenCompress"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card: Select Video -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Optimasi & Penjernih Video"
                        android:textColor="@color/whatsapp_green"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Pilih video portrait berkualitas tinggi dari galeri Anda untuk dikompresi secara presisi."
                        android:textColor="@color/gray_dark"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btnSelectVideo"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginTop="20dp"
                        android:backgroundTint="@color/whatsapp_green"
                        android:text="PILIH VIDEO DARI GALERI"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        app:cornerRadius="10dp" />

                    <TextView
                        android:id="@+id/tvSelectedFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Belum ada video yang dipilih."
                        android:textAlignment="center"
                        android:textColor="@color/gray_dark"
                        android:textSize="12sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Optimasi Penjernih (Ultra Clear) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mode Jernih Ultra (Enhancer)"
                            android:textColor="@color/black"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <!-- Switch untuk Mode Jernih -->
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchEnhance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:checked="true"
                            app:thumbTint="@color/whatsapp_green_light"
                            app:trackTint="@color/whatsapp_green" />

                    </RelativeLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Menggunakan filter unsharp mask profesional dan penyesuaian kontras cerdas untuk menjernihkan video yang burik sebelum dikirim ke WA!"
                        android:textColor="@color/gray_dark"
                        android:textSize="11sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Loading Progress Log (The "Cool" Progress Screen) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Status Pemrosesan Video"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/progressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:indeterminate="true"
                        android:progressTint="@color/whatsapp_green_light" />

                    <!-- Live Step Progress Logs -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/logStep1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="○ Membaca metadata &amp; orientasi video..."
                            android:textColor="@color/gray_dark"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/logStep2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="○ Menerapkan filter penajam (unsharp)..."
                            android:textColor="@color/gray_dark"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/logStep3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="○ Mengonversi audio ke standar stereo AAC..."
                            android:textColor="@color/gray_dark"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/logStep4"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="○ Melakukan encoding kompresi presisi x264..."
                            android:textColor="@color/gray_dark"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Big Action Buttons -->
            <Button
                android:id="@+id/btnProcessVideo"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/whatsapp_green_light"
                android:text="PROSES &amp; OPTIMALKAN VIDEO"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="10dp"
                tools:visibility="visible" />

            <Button
                android:id="@+id/btnShare"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/whatsapp_green"
                android:text="BAGIKAN KE STATUS WHATSAPP"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="10dp"
                tools:visibility="visible" />

        </LinearLayout>
    </ScrollView>

    <!-- SCREEN 2: STATUS SAVER (UNDUH STATUS) -->
    <LinearLayout
        android:id="@+id/screenSaver"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        tools:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status WhatsApp Teman"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Berikan izin ke folder status WhatsApp Anda untuk membackup status secara otomatis."
            android:textColor="@color/gray_dark"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnGrantFolder"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/whatsapp_green"
            android:text="BERIKAN IZIN FOLDER STATUS"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:cornerRadius="10dp" />

        <!-- Grid of Statuses -->
        <GridView
            android:id="@+id/gridStatuses"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="16dp"
            android:numColumns="3"
            android:horizontalSpacing="8dp"
            android:verticalSpacing="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvEmptySaver"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Belum ada status yang dimuat. Klik tombol hijau di atas."
            android:textColor="@color/gray_dark"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- SCREEN 3: STATUS TERHAPUS (RECOVERED) -->
    <LinearLayout
        android:id="@+id/screenDeleted"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        tools:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status Teman yang Terhapus"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Semua status yang dihapus oleh teman Anda sebelum 24 jam akan tetap tersimpan di sini!"
            android:textColor="@color/gray_dark"
            android:textSize="12sp" />

        <GridView
            android:id="@+id/gridDeleted"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="16dp"
            android:numColumns="3"
            android:horizontalSpacing="8dp"
            android:verticalSpacing="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvEmptyDeleted"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Belum mendeteksi adanya status yang dihapus."
            android:textColor="@color/gray_dark"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- FUTURISTIC BOTTOM NAVIGATION BAR -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="@color/white"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Tab 1: Compress -->
        <LinearLayout
            android:id="@+id/tabCompress"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTabCompress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HQ Upload"
                android:textColor="@color/whatsapp_green"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Tab 2: Saver -->
        <LinearLayout
            android:id="@+id/tabSaver"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTabSaver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unduh Status"
                android:textColor="@color/gray_dark"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Tab 3: Deleted -->
        <LinearLayout
            android:id="@+id/tabDeleted"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTabDeleted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status Terhapus"
                android:textColor="@color/gray_dark"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
